# PostgreSQL connection used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flash_proxy"

# FlashProxy upstream API. Use the sandbox URL if you are testing against sandbox keys.
FLASHPROXY_API_BASE_URL="https://rapi.flashproxy.com/api/v1"

# Generate strong random values for local development:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=""
API_KEY_ENCRYPTION_SECRET=""
